OPENAI_API_KEY=

# ── Shopify ──────────────────────────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=
SHOPIFY_UK_STORE_DOMAIN=
SHOPIFY_HK_STORE_DOMAIN=
SHOPIFY_ADMIN_TOKEN=

# ── TikTok Shop ────────────────────────────────────────────────────────────────
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
TIKTOK_SHOP_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_EVENTS_API_TOKEN=

# ── Discord ────────────────────────────────────────────────────────────────────
# Bot token (not webhook) — for posting as the bot to channels
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Channel IDs (Snowflake) for the execution engine to post to
DISCORD_VIP_CHANNEL_UK=
DISCORD_VIP_CHANNEL_HK=
DISCORD_ALERTS_CHANNEL=
DISCORD_REPORTS_CHANNEL=
# Discord webhook URL (legacy — used by the loop reporter)
DISCORD_WEBHOOK=

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_VIP_GROUP_UK=
WHATSAPP_VIP_GROUP_HK=

# ── Snapchat Ads ─────────────────────────────────────────────────────────────
SNAPCHAT_AD_ACCOUNT_ID=
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_REFRESH_TOKEN=

# ── eBay ───────────────────────────────────────────────────────────────────────
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REFRESH_TOKEN=

# ── Carousell ────────────────────────────────────────────────────────────────
CAROUSELL_MODE=manual

# ── Meta Ads ────────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ── Payment ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ── Scraping ────────────────────────────────────────────────────────────────
# Optional: proxy URL for scraping (avoids rate-limiting from Depop/Vestiaire/Xiaohongshu)
# SCRAPE_PROXY_URL=socks5://localhost:1080

# ── Auto Work Loop ────────────────────────────────────────────────────────
# Interval in seconds (default: 300 = 5 min)
# INTERVAL=300
