# ─────────────────────────────────────────────────────────────────────────────
# CLOTH — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local — it is already in .gitignore.
# Prefix: .env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────
# API key for AI-powered listing generation, customer support replies,
# video scripts, and ad brief generation.
OPENAI_API_KEY=sk-


# ══════════════════════════════════════════════════════════════════════════════
#  SHOPIFY — UK Store
# ══════════════════════════════════════════════════════════════════════════════
# Store domain: find in Shopify Admin → Settings → Domains
#   e.g. "yourstore.myshopify.com" (no https://)
#
# Admin API token:
#   1. Shopify Admin → Apps → Develop apps → Create an app
#   2. Configure Admin API scopes (read_products, write_products, read_orders,
#      write_orders, read_fulfillments, write_fulfillments)
#   3. Install app → copy the Admin API access token (shown ONCE)
#
# API Version: current stable is 2024-01
# ───────────────────────────────────────────────────────────────────────────
SHOPIFY_UK_STORE_DOMAIN=
SHOPIFY_UK_ADMIN_TOKEN=
SHOPIFY_UK_API_VERSION=2024-01


# ══════════════════════════════════════════════════════════════════════════════
#  SHOPIFY — HK Store
# ══════════════════════════════════════════════════════════════════════════════
# Same steps as UK store — repeat for your HK Shopify store.
# If both stores are under the same Shopify Org, you can reuse the same
# SHOPIFY_ADMIN_TOKEN with different store domains.
# ───────────────────────────────────────────────────────────────────────────
SHOPIFY_HK_STORE_DOMAIN=
SHOPIFY_HK_ADMIN_TOKEN=
SHOPIFY_HK_API_VERSION=2024-01

# Legacy / fallback (used when no market-specific domain is set)
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_TOKEN=


# ══════════════════════════════════════════════════════════════════════════════
#  TIKTOK SHOP
# ══════════════════════════════════════════════════════════════════════════════
# UK TikTok Shop integration via TikTok Shop Partner API.
# HK uses TikTok content pipeline (no direct Shop API yet).
#
# App Key + Secret:
#   1. Apply for TikTok Shop Seller account at seller-uk.tiktok.com
#   2. Get approved → go to Developer/Partner Portal
#   3. Create a Partner App → copy App Key and App Secret
#
# Access Token: obtained via OAuth with auth_code from TikTok Seller Center.
#   POST https://auth.tiktok-shops.com/oauth/token
#   Body: app_id, app_secret, auth_code, grant_type=authorized_code
#
# Advertiser ID: TikTok Ads Manager → Settings → Account
#
# Events API Token: TikTok Events Manager → Data Sources → Server → Generate Token
# ───────────────────────────────────────────────────────────────────────────
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
TIKTOK_SHOP_ACCESS_TOKEN=

# TikTok Ads (separate from TikTok Shop)
# Advertiser ID: TikTok Ads Manager → Account Settings
TIKTOK_ADVERTISER_ID=

# Server-side Events API token (for pixel/event forwarding)
TIKTOK_EVENTS_API_TOKEN=


# ══════════════════════════════════════════════════════════════════════════════
#  WHATSAPP BUSINESS
# ══════════════════════════════════════════════════════════════════════════════
# WhatsApp Business API for VIP drops and customer broadcasts.
#
# Setup:
#   1. business.facebook.com → Business Manager → add WhatsApp product
#   2. Register a phone number
#   3. WABA ID: Business Manager → WhatsApp → your number → WABA ID
#   4. Phone Number ID: same screen
#   5. Access Token: Meta Developer Console → Marketing API → Permanent token
#
# VIP Group IDs: right-click VIP WhatsApp group → Copy group link (for drops)
# ───────────────────────────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_VIP_GROUP_UK=
WHATSAPP_VIP_GROUP_HK=


# ══════════════════════════════════════════════════════════════════════════════
#  DISCORD
# ══════════════════════════════════════════════════════════════════════════════
# Discord bot for VIP drops, live alerts, and daily execution reports.
#
# Bot Setup:
#   1. discord.com/developers → New Application → create bot
#   2. Bot tab → Reset Token → copy Bot Token
#   3. Enable: Message Content Intent (Privileged Gateway Intents)
#   4. OAuth2 URL Generator → scopes: bot + applications.commands
#      permissions: Send Messages, Embed Links, Read Message History
#
# Server ID: enable Developer Mode (Settings → Advanced) → right-click server
# Channel IDs: enable Developer Mode → right-click each channel → Copy Channel ID
# ───────────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_VIP_CHANNEL_UK=
DISCORD_VIP_CHANNEL_HK=
DISCORD_ALERTS_CHANNEL=
DISCORD_REPORTS_CHANNEL=
# Legacy webhook URL (used by loop reporter — prefer bot token above)
DISCORD_WEBHOOK=


# ══════════════════════════════════════════════════════════════════════════════
#  SNAPCHAT ADS
# ══════════════════════════════════════════════════════════════════════════════
# Snapchat Ads API for HK budget fashion campaigns.
#
# Setup:
#   1. ads.snapchat.com → create account
#   2. Settings → API Access → create OAuth credentials
# ───────────────────────────────────────────────────────────────────────────
SNAPCHAT_AD_ACCOUNT_ID=
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_REFRESH_TOKEN=


# ══════════════════════════════════════════════════════════════════════════════
#  EBAY
# ══════════════════════════════════════════════════════════════════════════════
# eBay UK inventory and listing sync via OAuth.
#
# Setup:
#   1. developer.ebay.com → create developer account
#   2. Create application → copy Client ID and Client Secret
#   3. Follow OAuth flow to get refresh token
# ───────────────────────────────────────────────────────────────────────────
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REFRESH_TOKEN=


# ══════════════════════════════════════════════════════════════════════════════
#  META / FACEBOOK ADS
# ══════════════════════════════════════════════════════════════════════════════
# Meta Marketing API for retargeting and ad campaigns.
#
# Setup:
#   1. developers.facebook.com → create Business app
#   2. Add Marketing API product
#   3. Tools → Graph API Explorer → get User Access Token
#   4. Use to get Page Access Token + Ad Account ID
# ───────────────────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=


# ══════════════════════════════════════════════════════════════════════════════
#  PAYMENT PROCESSORS
# ══════════════════════════════════════════════════════════════════════════════
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=


# ══════════════════════════════════════════════════════════════════════════════
#  SCRAPING (optional)
# ══════════════════════════════════════════════════════════════════════════════
# Proxy URL to avoid rate-limiting when scraping Depop, Vestiaire, Carousell,
# Xiaohongshu. Format: socks5://host:port or http://host:port
# SCRAPE_PROXY_URL=socks5://localhost:1080


# ══════════════════════════════════════════════════════════════════════════════
#  AUTO WORK LOOP (optional)
# ══════════════════════════════════════════════════════════════════════════════
# Interval in seconds between work loop cycles (default: 300 = 5 minutes)
# Set to 0 to disable the auto loop.
# INTERVAL=300
